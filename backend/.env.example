# Server
NODE_ENV=development
PORT=5000
API_PREFIX=/api/v1

# MongoDB
MONGO_URI=mongodb://localhost:27017/milsys_rdc

# JWT
JWT_SECRET=MILSYS_RDC_SECRET_KEY_CHANGE_IN_PRODUCTION_2024
JWT_EXPIRE=8h
JWT_REFRESH_SECRET=MILSYS_RDC_REFRESH_SECRET_CHANGE_IN_PRODUCTION
JWT_REFRESH_EXPIRE=7d

# OTP / MFA
OTP_ISSUER=MILSYS-RDC
OTP_WINDOW=1

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Upload
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10

# Logging
LOG_LEVEL=info
LOG_FILE=logs/milsys.log
